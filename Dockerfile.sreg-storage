# 运行阶段：直接使用 GoReleaser 产出的二进制，不在 Docker 中重复编译
FROM alpine:3.19

RUN apk add --no-cache \
    bash \
    python3 \
    py3-yaml \
    tar \
    gzip \
    ca-certificates \
    tzdata \
    libgcc \
    gpgme \
    lvm2 \
    rclone

COPY sreg /usr/local/bin/sreg
COPY scripts/sreg-storage.sh /usr/local/bin/sreg-storage.sh
RUN chmod +x /usr/local/bin/sreg /usr/local/bin/sreg-storage.sh

WORKDIR /tmp/sreg-storage
ENTRYPOINT ["/usr/local/bin/sreg-storage.sh"]
CMD ["--help"]
